# Webflow API Configuration
# Get your API token from: https://webflow.com/dashboard/account/apps
WEBFLOW_API_TOKEN=your_webflow_api_token_here

# GitHub Personal Access Token (required for icon uploads)
# Get your token from: https://github.com/settings/tokens
# Scopes needed: 
#   - public_repo (for reading BAR repository)
#   - repo (for writing to your icon repository)
GITHUB_TOKEN=your_github_token_here

# GitHub Icon Repository Configuration (for --sync-icons feature)
# This is YOUR repository where converted WebP icons will be committed
# The icons will be publicly accessible via GitHub raw URLs
ICON_REPO_OWNER=your_github_username
ICON_REPO_NAME=bar-unit-sync
ICON_BRANCH=main

# Auto-publish updated items (true/false)
# If true, items will be automatically published after updating
# If false, items will be saved as drafts
AUTO_PUBLISH=false

# Optional: Override default values
# GITHUB_REPO=beyond-all-reason/Beyond-All-Reason
# GITHUB_BRANCH=master
# WEBFLOW_SITE_ID=5c68622246b367adf6f3041d
# WEBFLOW_COLLECTION_ID=6564c6553676389f8ba45a9e
